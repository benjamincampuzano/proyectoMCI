{
  "name": "proyecto-iglesia",
  "version": "1.0.0",
  "description": "Congregation CRM Web App",
  "scripts": {
    "start": "pnpm run migrate && pnpm exec concurrently -n \"server,client\" -c \"yellow,blue\" \"pnpm run server\" \"pnpm run client\"",
    "server": "pnpm -C server run dev",
    "client": "pnpm -C client run dev",
    "migrate": "pnpm -C server run migrate",
    "install:all": "pnpm install",
    "backup": "node scripts/backup-db.js",
    "restore": "node scripts/restore-db.js",
    "create-test-users": "node scripts/create-test-users.js",
    "delete-test-users": "node scripts/delete-test-users.js",
    "verify-users": "node scripts/verify-users.js",
    "check-roles": "node scripts/check-roles.js",
    "manage-users": "node scripts/manage-test-users.js",
    "menu-usuarios": "node scripts/menu-usuarios.js",
    "test:open": "cypress open",
    "test:run": "cypress run"
  },
  "keywords": [],
  "author": "Benjamin Campuzano Castañeda",
  "license": "ISC",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cypress": "^15.15.0",
    "vite": "^8.0.13"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "dotenv": "^17.4.2",
    "file-saver": "^2.0.5",
    "next": "^16.2.6",
    "xlsx": "^0.18.5"
  }
}
