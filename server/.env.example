# Database
# Add connection_limit and pool_timeout to prevent pool exhaustion
# Format: postgresql://user:pass@host:port/db?connection_limit=20&pool_timeout=20
DATABASE_URL="postgresql://username:password@host:port/database?connection_limit=20&pool_timeout=20"

# JWT
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="30m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV="production"

# CORS (optional)
FRONTEND_URL="https://your-railway-app-url.railway.app"

# Security & Threat Detection APIs
GOOGLE_CLOUD_API_KEY="your-google-cloud-api-key-here"
URLHAUS_API_KEY="your-urlhaus-api-key-here"
CLOUDMERSIVE_API_KEY="your-cloudmersive-api-key-here"
